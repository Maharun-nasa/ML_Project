        "# Encoding the Categorical variables for numerical analysis .\n",
        "\n",
        "from sklearn.preprocessing import LabelEncoder\n",
        "le=LabelEncoder()\n",
        "\n",
        "df2['Gender']=le.fit_transform(df2['Gender'])\n",
        "df2['City']=le.fit_transform(df2['City'])\n",
        "df2['Product line']=le.fit_transform(df2['Product line'])\n",
        "df2['Payment']= le.fit_transform(df2['Payment'])\n",
        "df2['Customer type']= le.fit_transform(df2['Customer type'])\n",
        "df2"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "376685fd",
      "metadata": {
        "id": "376685fd"
      },
      "outputs": [],
      "source": [
        "x = df2[[ 'Unit price','Gender','Product line','City','Customer type','Quantity','Payment']]\n",
        "y = df2['High rating']"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "3ce6eaff",
      "metadata": {
        "id": "3ce6eaff",
        "outputId": "0f5e6572-e4c1-4d72-8a65-b9cbcf5b502c"
      },
      "outputs": [
        {
          "name": "stdout",
          "output_type": "stream",
